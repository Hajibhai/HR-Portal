rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Creator' ||
         (request.auth.token.email == "abdulkaderp3010@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCreator() {
      return isAuthenticated() && 
        (request.auth.token.email == "abdulkaderp3010@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasPermission(permission) {
      return isAuthenticated() && 
        (isCreator() || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions[permission] == true));
    }

    match /audit_logs/{logId} {
      allow read: if isAuthenticated() && (
        isCreator() || 
        (hasPermission('canManageSettings') || hasPermission('canManageUsers') || hasPermission('canManageEmployees'))
      );
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || hasPermission('canManageUsers');
      allow create: if isAuthenticated() && (isOwner(userId) || hasPermission('canManageUsers'));
      allow update: if isAuthenticated() && (isOwner(userId) || hasPermission('canManageUsers'));
      allow delete: if hasPermission('canManageUsers');
    }

    match /employees/{employeeId} {
      allow read: if hasPermission('canViewDirectory') || hasPermission('canManageEmployees');
      allow write: if hasPermission('canManageEmployees');
    }

    match /attendance/{recordId} {
      allow read: if hasPermission('canViewTimesheet') || hasPermission('canManageAttendance');
      allow write: if hasPermission('canManageAttendance');
    }

    match /leaves/{leaveId} {
      allow read: if hasPermission('canManageLeaves');
      allow write: if hasPermission('canManageLeaves') || isAuthenticated();
    }

    match /deductions/{deductionId} {
      allow read: if hasPermission('canViewPayroll') || hasPermission('canManagePayroll');
      allow write: if hasPermission('canManagePayroll');
    }

    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('canManageSettings');
    }

    match /settings/about {
      allow read: if true;
      allow write: if hasPermission('canManageSettings');
    }
  }
}
